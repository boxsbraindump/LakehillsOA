# Copy this file to .env.local and fill in real values after deploying worker/
# and creating a Google OAuth Client ID. Without both set, the app runs exactly
# as before — local-only, no cloud sync, no login screen.

VITE_API_BASE=https://lakehills-oa-api.YOUR-SUBDOMAIN.workers.dev
VITE_GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
